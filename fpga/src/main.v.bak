module main
(
    input clk_50M, rstn,
    output  [5:0] sel,
    output  [7:0] seg,
    output  clk_100M,

    // ADC
    input d_in,
    input [1:0] channel,
    output sclk, csn, d_out,

    // C
    input c_signal
);
    pll pll_inst
    (
        .inclk0(clk_50M),
        .c0(clk_100M)
    );

    wire clk_1k;
    DIV #(.NUM_DIV(100000)) div1k(clk_100M, rstn, clk_1k);

    wire [19:0] mvoltage;  // UQ11.9
    wire adc_done;
    ADC adc_inst
    (
        .clk(clk_100M),
        .rstn(rstn),
        .d_in(d_in),
        .channel(channel),
        .mvoltage(mvoltage),
        .sclk(sclk),
        .csn(csn),
        .d_out(d_out),
        .done(adc_done)
    );

    wire freq_done;
    wire [31:0] m, n;
    FreqMeasure fq
    (
        .clk(clk_100M),
        .rstn(rstn),
        .signal(c_signal),
        .done(freq_done),
        .m(m),
        .n(n)
    );

    wire [36:0] c_res;
    wire c_done
    CMeasure cMeasure (
        .clk      (clk_100M),
        .rstn     (rstn),
        .freq_done(freq_done),
        .m        (m),
        .n        (n),
        .c        (c_res),
        .done     (c_done)
    );

    wire [19:0] rg_bin;
    wire [5:0] point;
    RangeSelector rg_selector
    (
        .clk(clk_100M),
        .rstn(rstn),
        .start(c_done),
        .in(c_res),
        .in_range(3'd0),
        .out(rg_bin),
        .point(point),
        .out_range(),
        .done()
    );

    wire dgt_update;
    CTU #(
        .N(100)
    ) dgt_update_ctu (
        .clk(clk_1k),
        .rstn(rstn),
        .count(),
        .carry(dgt_update)
    );

    reg [19:0] dgt_bin;
    always @(posedge dgt_update or negedge rstn)
    begin
        if (!rstn)
        begin
            dgt_bin <= 20'd0;
        end
        else
        begin
            dgt_bin <= rg_bin;
        end
    end

    wire [23:0] dgt_bcd;
    BIN2BCD #(
        .W(20),
        .BCD_WIDTH(24)
    ) bin2bcd (
        .bin(dgt_bin),
        .bcd(dgt_bcd)
    );

    BCDDGT dgt(clk_1k, rstn, dgt_bcd, point, sel, seg);
endmodule

module RangeSelector
(
    input clk, rstn, start,
    input [36:0] in,  // UQ20.17
    input [2:0] in_range,  // 0:p，6:M, 7:OL
    output [19:0] out,
    output [5:0] point,
    output [2:0] out_range,  // 0:p，6:M, 7:OL
    output done
);
    localparam IDLE = 2'b00, LATCH = 2'b01, TRANS = 2'b10, MULT = 2'b11;
    reg [1:0] stn;
    wire [1:0] stc;
    FSM #(
        .N(4),
        .INITIAL_STATE(IDLE)
    ) fsm_inst
    (
        .clk(clk),
        .rstn(rstn),
        .stn(stn),
        .stc(stc)
    );

    always @(*)
    begin
        case (stc)
            IDLE: stn = start ? LATCH : IDLE;
            LATCH: stn = MULT;
            TRANS: stn = finish_condition ? IDLE : MULT;
            MULT: stn = TRANS;
            default: stn = IDLE;
        endcase
    end

    wire [19:0] target_num;
    reg [36:0] fp_num;
    UnsignedFixedPointNorm #(
        .Q_IN_INT(20),
        .Q_IN_FRAC(17),
        .Q_OUT_INT(20),
        .Q_OUT_FRAC(0)
    ) norm_inst (
        .in(fp_num),
        .out(target_num)
    );

    wire [36:0] mult10_result;
    UnsignedFixedPointMult #(
        .Q_IN_INT_A(20),
        .Q_IN_FRAC_A(17),
        .Q_IN_INT_B(4),
        .Q_IN_FRAC_B(0),
        .Q_OUT_INT(20),
        .Q_OUT_FRAC(17)
    ) mult10 (
        .clk(clk),
        .rstn(rstn),
        .in_a(fp_num),
        .in_b(4'd10),
        .out(mult10_result)
    );

    assign finish_condition = (target_num >= 20'd10_000 && r_point == 6'b100_000) || (target_num >= 20'd100_000) || (r_range == 3'd7);

    reg r_done;
    reg [5:0] r_point;
    reg [2:0] r_range;
    always @(posedge clk or negedge rstn)
    begin
        if (!rstn)
        begin
            r_done <= 1'b0;
            r_point <= 6'b000_000;
            r_range <= 3'd0;
            fp_num <= 37'd0;
        end
        else
        begin
            case (stc)
                IDLE:
                begin
                    r_done <= 1'b0;
                    r_point <= r_point;
                    r_range <= r_range;
                    fp_num <= fp_num;
                end

                LATCH:
                begin
                    r_done <= 1'b0;
                    r_point <= 6'b000_001;
                    r_range <= in_range;
                    fp_num <= in;
                end

                TRANS:
                begin
                    r_done <= finish_condition;
                    r_range <= r_range;
                    if (finish_condition)
                    begin
                        fp_num <= fp_num;
                        r_point <= r_point;
                        r_done <= 1'b1;
                    end
                    else if (r_point != 6'b100_000)
                    begin
                        fp_num <= mult10_result;
                        r_point <= r_point << 1;
                    end
                    else if (r_range != 3'd0)
                    begin
                        fp_num <= fp_num;
                        r_point <= 6'b000_100;
                        r_range <= r_range - 3'd1;
                    end
                    else
                    begin
                        fp_num <= 37'd0;
                        r_point <= r_point;
                        r_range <= 3'd7;
                    end
                end

                default:
                begin
                    r_done <= 1'b0;
                    r_range <= r_range;
                    r_point <= r_point;
                    fp_num <= fp_num;
                end
            endcase
        end
    end


    assign done = r_done;

    reg [19:0] rr_out;
    reg [5:0] rr_point;
    reg [2:0] rr_out_range;
    always @(posedge done or negedge rstn)
    begin
        if (!rstn)
        begin
            rr_out <= 20'd0;
            rr_point <= 6'd0;
            rr_out_range <= 3'd0;
        end
        else
        begin
            rr_out <= target_num;
            rr_point <= r_point;
            rr_out_range <= r_range;
        end
    end

    assign out = rr_out;
    assign point = rr_point;
    assign out_range = rr_out_range;

endmodule

module ADC
(
    input clk, rstn, d_in,
    input [1:0] channel,
    output [19:0] mvoltage,  // UQ11.9
    output sclk, csn, d_out, done
);
    wire [15:0] code;
    wire ads1118_done;
    ADS1118 ads1118_inst
    (
        .clk(clk),
        .rstn(rstn),
        .d_in(d_in),
        .channel(channel),
        .data(code),
        .sclk(sclk),
        .csn(csn),
        .d_out(d_out),
        .done(ads1118_done)
    );

    reg [19:0] adc_code;  // UQ15.5，5位用于32次累加
    reg [4:0] cnt;
    reg [19:0] r_mvoltage;  // UQ11.9
    reg r_done;
    always @(posedge ads1118_done or negedge rstn)
    begin
        if (!rstn)
        begin
            cnt <= 5'd0;
            adc_code <= 15'b0;
            r_mvoltage <= 20'b0;
            r_done <= 1'b0;
        end
        else
        begin
            if (cnt < 5'd31)
            begin
                cnt <= cnt + 5'd1;
                adc_code <= adc_code + code[14:0];
                r_mvoltage <= r_mvoltage;
                r_done <= 1'b0;
            end
            else
            begin
                cnt <= 5'd0;
                r_mvoltage <= adc_code;
                adc_code <= code[14:0];
                r_done <= 1'b1;
            end
        end
    end

    assign mvoltage = r_mvoltage;
    assign done = r_done;
endmodule

module CMeasure
(
    input clk, rstn, freq_done,
    input [31:0] m, n,
    output [36:0] c,  // UQ20.17
    output done
);
    localparam K = 32'd388978170;  // UQ0.32, 144/1590

    wire [31:0] raw; // UQ17.15
    UnsignedFixedPointDiv #(
        .Q_IN_INT_A(32),
        .Q_IN_FRAC_A(0),
        .Q_IN_INT_B(32),
        .Q_IN_FRAC_B(0),
        .Q_OUT_INT(17),
        .Q_OUT_FRAC(15)
    ) div_inst (
        .clk(clk),
        .rstn(rstn),
        .in_a(m),
        .in_b(n),
        .out(raw)
    );

    wire [36:0] res;
    UnsignedFixedPointMult #(
        .Q_IN_INT_A(0),
        .Q_IN_FRAC_A(32),
        .Q_IN_INT_B(17),
        .Q_IN_FRAC_B(15),
        .Q_OUT_INT(20),
        .Q_OUT_FRAC(17)
    ) mult_inst (
        .clk(clk),
        .rstn(rstn),
        .in_a(K),
        .in_b(raw),
        .out(res)
    );

    reg [36:0] l_res;
    reg [1:0] wait_ctn;
    reg is_waiting;
    reg r_done;
    always @(posedge clk or negedge rstn)
    begin
        wait_ctn <= 2'b0;
        r_done <= 1'b0;
        l_res <= l_res;
        if (!rstn)
        begin
            is_waiting <= 1'b0;
        end
        else
        begin
            if (freq_done && !is_waiting)
            begin
                is_waiting <= 1'b1;
            end
            else if (is_waiting)
            begin
                wait_ctn <= wait_ctn + 2'b1;
                if (wait_ctn == 2'b11)
                begin
                    wait_ctn <= 2'b00;
                    is_waiting <= 1'b0;
                    l_res <= res;
                    r_done <= 1'b1;
                end
            end
        end
    end

    assign done = r_done;
    assign c = l_res;
endmodule
